# Copia este archivo como .env para desarrollo local fuera de Docker.
# En Docker, las variables se pasan directamente desde docker-compose.yml.

DJANGO_SETTINGS_MODULE=core.settings.development
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=1
DATABASE_URL=postgres://finance_user:finance_password@localhost:5432/finance_db
CELERY_BROKER_URL=redis://localhost:6379/0
